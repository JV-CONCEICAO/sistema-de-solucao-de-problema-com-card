<header>
    <nav class="navbar">
        <div class="itens-esquerda" >
            <a href="#" class="logo-link">
                <i class="fa-solid fa-layer-group icone" style="color: #10B981; margin-right: 8px;"></i>
                <h1 class="titulo">DEV VAULT</h1>
            </a>
        </div>

        <div class="itens-direita" >
            <ul class="lista-itens">
                <li class="task-pending">Problemas resolvidos: 15</li>
