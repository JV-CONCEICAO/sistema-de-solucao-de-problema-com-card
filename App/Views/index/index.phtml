<main class="main-corpo">
    <section class="section-left">
        <form   method="post" action="/registraProblemaSolucao" class="form-column">
            <div class="input-group">
                <label class="label-style" for="title-form">Titúlo do problema resolvido:</label>
                <input class="input-style" name="title-form" id="title-form" type="text" placeholder="Exempo: Erro na api">
            </div>
            <div class="seletor-group">
                <label class="label-style" for="seletor-category">Categoria:</label>
                <select class="seletor-style" name="seletor-category" id="seletor-category">
                <option value="" disabled selected>Selecione uma Categoria</option>
                <option value="Java">Java</option>
                <option value="PHP">PHP</option>
                <option value="JavaScript">JavaScript</option>
            </select>
            </div>
            <div class="text-area-group">
                <label class="label-style" for="description-form">Descrição do problema:</label>
                <textarea placeholder="Descrição" class="description" name="description-form" id="description-form"></textarea>
            </div>
            <button class="button-style" type="submit">CLIQUE AQUI PARA ENVIAR</button>
        </form>
    </section>
    <section class="section-right">
        <!-- Cada item adicionado é um item proprio logo pode ser usado uma article -->
